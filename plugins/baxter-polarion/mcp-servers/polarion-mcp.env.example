# PolarionMCP configuration
# Copy to ~/.config/polarion-mcp.env and fill in your values.
# chmod 600 ~/.config/polarion-mcp.env

POLARION_URL=http://polarion.example.com/polarion
POLARION_USER=myuser
# Set either POLARION_PASSWORD or POLARION_PAT (PAT is tried first when both are set).
POLARION_PASSWORD=secret
# POLARION_PAT=your_personal_access_token
POLARION_PROJECT=MY_PROJECT

# Optional
# POLARION_MCP_LOG_LEVEL=WARNING
# POLARION_MCP_MAX_CALLS=100
# POLARION_TEST_RESULT_PASSED_ID=passed
# POLARION_TEST_RESULT_FAILED_ID=failed
# POLARION_APPROVAL_STATUS_WAITING_ID=waiting
# POLARION_DEFAULT_LINK_ROLE=relates_to
