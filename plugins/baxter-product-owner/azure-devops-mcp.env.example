# Azure DevOps MCP configuration
# Copy to ~/.config/azure-devops-mcp.env (Linux/macOS)
# or %USERPROFILE%\.config\azure-devops-mcp.env (Windows)
# chmod 600 ~/.config/azure-devops-mcp.env

ADO_ORG=FLC-NPD
ADO_AUTH=pat

# Personal Access Token — use one of these variable names:
# AZURE_DEVOPS_EXT_PAT=your_pat_here
# ADO_PAT=your_pat_here
# ADO_MCP_AUTH_TOKEN=your_pat_here
AZURE_DEVOPS_EXT_PAT=your_pat_here

# Optional defaults
# ADO_PROJECT=FutureState
