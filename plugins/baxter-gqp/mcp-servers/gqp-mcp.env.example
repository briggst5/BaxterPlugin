# GQP MCP configuration (non-secret settings)
# Copy to ~/.config/gqp-mcp.env and chmod 600
#
# Auth model (same approach as the CFCT tool): the MCP authenticates to Entra using your
# AMBIENT Baxter identity - Windows sign-in (WAM/SSO), Visual Studio, or the Azure CLI - and
# reads the backend API keys from Key Vault. There is NO custom app registration, NO client
# secret, and NO per-user consent prompt. Access is governed by your Azure RBAC on the vault
# (you need "Key Vault Secrets User" on the vault below).
#
# After the first successful read, the keys are cached locally
# (~/.config/gqp-mcp.secrets.json, owner-only) so later sessions need no sign-in at all.

# Baxter tenant - pins sign-in to Baxter Entra
AZURE_TENANT_ID=f4dcdb22-a4c7-4f4c-a390-1954365b828c

# Key Vault that holds the backend API keys (gqp-azure-search-key, gqp-azure-openai-key).
GQP_KEYVAULT_NAME=kv-flc-copilot

AZURE_SEARCH_ENDPOINT=https://baxter-platform-docs.search.windows.net
AZURE_OPENAI_ENDPOINT=https://aoi-flc-copilot-platform.openai.azure.com/
AZURE_GPT_ENDPOINT=https://aoi-flc-copilot-platform.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01

# Maintainers/indexers only - personal AIServices resource for bulk embedding (Python indexer).
# The .NET MCP embeds via AZURE_OPENAI_ENDPOINT above; this is unused by the MCP itself.
# AZURE_EMBED_ENDPOINT=https://thoma-mjejw55r-eastus2.cognitiveservices.azure.com/

# Indexer throttling when using a shared embedding deployment (429 Too Many Requests)
# GQP_EMBED_BATCH_SIZE=8
# GQP_EMBED_DELAY_SECONDS=30

# TLS - Baxter corporate proxy / WSL (see docs/keyvault-setup.md)
# If tools fail with "certificate verify failed" or "self-signed certificate in chain":
# GQP_TLS_CA_FILE=/usr/local/share/ca-certificates/proxy-baxter-healthcare.crt
# Or install system-wide: sudo cp *.crt /usr/local/share/ca-certificates/ && sudo update-ca-certificates
# Dev workaround only (not for production):
# GQP_TLS_SKIP_VERIFY=true

# Optional
# GQP_MCP_LOG_LEVEL=WARNING
